        "def predict_message(message: str):\n",
        "    cleaned = preprocess_text(message)\n",
        "    vector = tfidf.transform([cleaned])\n",
        "\n",
        "    nb_pred = nb_model.predict(vector)[0]\n",
        "    lr_pred = lr_model.predict(vector)[0]\n",
        "\n",
        "    nb_conf = max(nb_model.predict_proba(vector)[0]) * 100\n",
        "    lr_conf = max(lr_model.predict_proba(vector)[0]) * 100\n",
        "\n",
        "    print(\"-\" * 50)\n",
        "    print(f\"Input Text: {message}\")\n",
        "    print(f\"NB Prediction: {nb_pred.upper()} ({nb_conf:.1f}% confidence)\")\n",
        "    print(f\"LR Prediction: {lr_pred.upper()} ({lr_conf:.1f}% confidence)\")\n",
        "\n",
        "sample_messages = [\n",
        "    \"Congratulations! You've won a FREE iPhone. Click here NOW to claim your prize!\",\n",
        "    \"Hey, are we still on for lunch tomorrow at noon?\",\n",
        "    \"URGENT: Your bank account has been suspended. Call us immediately to verify.\"\n",
        "]\n",
        "\n",
        "for msg in sample_messages:\n",
        "    predict_message(msg)"
      ],
